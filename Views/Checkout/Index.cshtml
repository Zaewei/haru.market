
@section Styles {
    <link rel="stylesheet" href="~/css/checkout/checkout.css" />
}
    
<div class="Checkout_Main_Container">

    <div class="Checkout_Details_Container">

        <div class="Checkout_Details_Title">

            <h4>Checkout Details</h4>

        </div>

        <div class="Checkout_Details_Form">

            <div class="Contact_Information_Form">
                <div class="Title_Contact_Information_Form">

                    <h5>Contact Information</h5>

                </div>

                <div class="Name_Contact_Information_Form">
                    <input type="text" placeholder="First name" class="Fname_input">
                    <input type="text" placeholder="Last name" class="Lname_input">
                </div>

                <div class="Email_Contact_Information_Form">
                    <input type="text" placeholder="Email">
                </div>                


            </div>

            <div class="Delivery_Details_Form">

                <div class="Title_Delivery_Details_Form">
                    
                    <h5>Delivery Details</h5>

                </div>

                <div class="Input_Delivery_Details_Form">
                    <input type="text" placeholder="Address" class="Address_input">
                    <input type="text" placeholder="City" class="City_input">
                    <input type="text" placeholder="Postal Code" class="Postal_input">
                    <input type="text" placeholder="Phone Number" class="Phonenum_input">
                </div>
            </div>

            <div class="Payment_Method_Buttons">
                <div class="Title_Payment_Method_Buttons">
                    <h6>Payment Methods</h6>

                </div>

                <div class="Buttons_Payment_Method">

                    <label class="radio-option">
                        <input type="radio" name="PaymentMethod" value="CashOnDelivery" checked>
                        Cash on Delivery
                    </label>

                    <label class="radio-option">
                        <input type="radio" name="PaymentMethod" value="GCash">
                        GCash
                    </label>

                    <label class="radio-option">
                        <input type="radio" name="PaymentMethod" value="Maya">
                        Maya
                    </label>

                </div>

            </div>

        </div>

        <div class="Checkout_Details_Button">

            <button>Checkout</button>

        </div>

    </div>


    <div class="Checkout_Cart_Summary_Container">

        <div class="Title_Checkout_Cart_Summary_Container">
            <h5>My Bag</h5>
        </div>

        <div class="Content_Checkout_Cart_Summary_Container">

            <div class="Checkout_Product_Card">

                <div class="Picture_Checkout_Product_Card">

                    <div class="Badge_Picture_Checkout_Product_Card">
                        <p>(#)</p>
                    </div>
                    <img src="" alt="">

                </div>

                <div class="Description_Checkout_Product_Card">
                    <h5>(Product Title)</h5>
                    <h6>₱(price)</p>
                    <p>Size: (size)</p>
                    <p>(color)<p/>
                </div>
            </div>

            <div class="Checkout_Product_Card">

                <div class="Picture_Checkout_Product_Card">

                    <div class="Badge_Picture_Checkout_Product_Card">
                        <p>(#)</p>
                    </div>
                    <img src="" alt="">

                </div>

                <div class="Description_Checkout_Product_Card">
                    <h5>(Product Title)</h5>
                    <h6>₱(price)</p>
                    <p>Size: (size)</p>
                    <p>(color)<p/>
                </div>
            </div>

            <div class="Checkout_Product_Card">

                <div class="Picture_Checkout_Product_Card">

                    <div class="Badge_Picture_Checkout_Product_Card">
                        <p>(#)</p>
                    </div>
                    <img src="" alt="">

                </div>

                <div class="Description_Checkout_Product_Card">
                    <h5>(Product Title)</h5>
                    <h6>₱(price)</p>
                    <p>Size: (size)</p>
                    <p>(color)<p/>
                </div>
            </div>

        </div>

        <div class="Bottom_Space_Checkout_Cart_Summary_Container">.

        </div>


    </div> 


</div>