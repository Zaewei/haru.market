@model haru.market.Models.OrderPlacementViewModel

<div class="container" style="max-width: 700px; padding: 40px 20px;">
    <h2 style="font-weight: 700; margin-bottom: 5px;">Checkout</h2>
    <hr style="border: 0; border-top: 1px solid #eee; margin-bottom: 30px;" />

    <form asp-action="ProcessCheckout" method="post">
        <h4 style="margin-bottom: 20px; font-weight: 600;">Delivery Destination Form</h4>
        
        <div style="margin-bottom: 20px;">
            <label asp-for="CustomerName" style="display:block; font-weight:600; margin-bottom:5px;">Recipient Full Name</label>
            <input asp-for="CustomerName" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
            <span asp-validation-for="CustomerName" style="color: red; font-size: 13px;"></span>
        </div>

        <div style="margin-bottom: 20px;">
            <label asp-for="CustomerEmail" style="display:block; font-weight:600; margin-bottom:5px;">Contact Email Address</label>
            <input asp-for="CustomerEmail" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
            <span asp-validation-for="CustomerEmail" style="color: red; font-size: 13px;"></span>
        </div>

        <div style="margin-bottom: 30px;">
            <label asp-for="ShippingAddress" style="display:block; font-weight:600; margin-bottom:5px;">Full Delivery Destination Location</label>
            <input asp-for="ShippingAddress" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
            <span asp-validation-for="ShippingAddress" style="color: red; font-size: 13px;"></span>
        </div>

        <h4 style="margin-bottom: 20px; font-weight: 600;">Standardized Basket Summary</h4>
        @for (int i = 0; i < Model.Items.Count; i++)
        {
            <div style="background: #fdfdfd; padding: 20px; border: 1px solid #eaeaea; border-radius: 6px; margin-bottom: 20px;">
                <input type="hidden" asp-for="Items[i].ProductId" />
                
                <div style="margin-bottom: 10px;">
                    <strong>Product:</strong> <input asp-for="Items[i].ProductName" readonly style="border:none; background:transparent; font-weight:500;" />
                </div>
                <div style="margin-bottom: 10px;">
                    <strong>Unit Price:</strong> $<input asp-for="Items[i].Price" readonly style="border:none; background:transparent;" />
                </div>
                <div>
                    <label style="font-weight: 500;">Checkout Quantity:</label>
                    <input asp-for="Items[i].Quantity" type="number" style="width: 60px; padding: 5px; border:1px solid #ddd; border-radius:4px;" />
                </div>
            </div>
        }

        <button type="submit" style="background: #000; color: white; width: 100%; padding: 14px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; margin-top: 15px;">
            Authorize & Process Order Fulfillment
        </button>
    </form>
</div>