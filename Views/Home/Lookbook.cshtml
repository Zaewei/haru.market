@using System.Text.Encodings.Web
@model IEnumerable<haru.market.Models.LookbookViewModel>
@{
    ViewData["Title"] = "Lookbook Experience";
    var campaignsList = Model?.ToList() ?? new List<haru.market.Models.LookbookViewModel>();
    var initialCampaign = campaignsList.FirstOrDefault();

    var wishlistIds = ViewBag.WishlistIds as List<string> ?? new List<string>();

    bool isWishlisted = initialCampaign != null && wishlistIds.Contains(initialCampaign.Id ?? "");
}

@section Styles {
    <link rel="stylesheet" href="~/css/costumer_page/Lookbook.css" asp-append-version="true" />
}

<section class="LookbookSection">
    <div class="LookBookPreview_container">
        @if (ViewBag.HeroBannerUrls != null)
        {
            foreach (var url in (List<string>)ViewBag.HeroBannerUrls)
            {
                <div class="slide" style="background-image: url('@url');"></div>
            }
        }
    </div>
</section>

<div class="haru-storefront-sets-wrap">
    @if (campaignsList.Any() && initialCampaign != null)
    {
        <div class="haru-storefront-grid">
            
            <div class="haru-thumb-stack">
                @for (int i = 0; i < campaignsList.Count; i++)
                {
                    var camp = campaignsList[i];
                    <div class="haru-thumb-item @(i == 0 ? "active-thumb" : "")" 
                         style="background-image: url('@camp.MediaUrl');"
                         onclick="switchStorefrontCampaign(this, '@camp.MediaUrl', '@JavaScriptEncoder.Default.Encode(camp.ThemeTitle)', '@JavaScriptEncoder.Default.Encode(camp.Description)', '@camp.Id')">
                    </div>
                }
            </div>
            
            <div class="haru-main-display-frame">
                <img id="mainLookbookImage" src="@initialCampaign.MediaUrl" alt="@initialCampaign.ThemeTitle" />
            </div>
            
            <div class="haru-narrative-panel">
                <h2 id="mainLookbookTitle" class="haru-narrative-title">@initialCampaign.ThemeTitle</h2>
                <p id="mainLookbookDescription" class="haru-narrative-desc">@initialCampaign.Description</p>
                
                <div style="display: flex; gap: 15px; align-items: center;">
                    <a href="/Home/Shop" class="haru-action-btn-primary">
                        View in shop
                    </a>
                    
                    <form asp-controller="Lookbook" asp-action="SaveToWishlist" method="post" style="display: inline;">
                        <input type="hidden" name="lookbookId" id="wishlistLookbookId" value="@initialCampaign.Id" />
                        <button type="submit" class="haru-action-btn-heart @(isWishlisted ? "wishlisted" : "")">
                            <svg id="wishlistHeart" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="@(isWishlisted ? "#C96A7F" : "none")" stroke="@(isWishlisted ? "#C96A7F" : "currentColor")" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </button>
                    </form>
                </div>
            </div>

        </div>
    }
    else
    {
        <div class="haru-storefront-grid" style="justify-content: center; text-align: center;">
            <div style="padding: 50px 20px;">
                <h2 style="font-family: 'Times New Roman', serif; font-size: 2.2rem; margin: 0 0 10px 0;">Collections Coming Soon</h2>
                <p style="color: #666; margin: 0;">Our design track team is currently assembling the next seasonal capsule catalog drops. Check back shortly!</p>
            </div>
        </div>
    }
</div>

<script>
    const wishlistIds = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(wishlistIds));

    function switchStorefrontCampaign(thumbnailElement, mediaUrl, title, description, id)
    {
        document.getElementById('mainLookbookImage').src = mediaUrl;
        document.getElementById('mainLookbookTitle').innerText = title;
        document.getElementById('mainLookbookDescription').innerText = description;
        document.getElementById('wishlistLookbookId').value = id;

        const heart = document.getElementById('wishlistHeart');
        if (wishlistIds.includes(id))
        {
            heart.setAttribute('fill', '#C96A7F');
            heart.setAttribute('stroke', '#C96A7F');
        }
        else
        {
            heart.setAttribute('fill', 'none');
            heart.setAttribute('stroke', 'currentColor');
        }

        const thumbnails = document.querySelectorAll('.haru-thumb-item');
        thumbnails.forEach(t => t.classList.remove('active-thumb'));
        thumbnailElement.classList.add('active-thumb');
    }
</script>
