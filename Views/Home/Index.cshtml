@model haru.market.Controllers.HomeViewModel
@using haru.market.Models
@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/costumer_page/Index.css" asp-append-version="true" />
}

<section class="LookbookSection">
    <div class="LookBookSection_container">
        @if (ViewBag.HeroBannerUrls != null)
        {
            foreach (var url in (List<string>)ViewBag.HeroBannerUrls)
            {
                <div class="slide" style="background-image: url('@url'); background-size: cover; background-position: center;"></div>
            }
        }
    </div>

    <div class="LookBookSection_text">
        <a href="/Lookbook" class="lookbook-link">Explore Lookbook</a>
    </div>
</section>

<section class="FeaturedSection">
    <div class="FeaturedSection_container">
        <h2>FEATURED</h2>
        <div class="FeaturedItem_Container">
            <div class="infinite-scroll-wrapper">
                @if (ViewData.Model.Products != null)
                {
                    var featuredProducts = ((IEnumerable<ProductViewModel>)ViewData.Model.Products).Take(5).ToList();
                    
                    <!-- Loop 1 -->
                    @foreach (var product in featuredProducts)
                    {
                        <div class="FeaturedItem_card">
                            <img src="@product.ImageUrl" onerror="this.src='https://placehold.co/150?text=Product';" />
                            <h6>@product.Name</h6>
                            <p>₱@product.Price</p>
                        </div>
                    }
                    <!-- Loop 2 -->
                    @foreach (var product in featuredProducts)
                    {
                        <div class="FeaturedItem_card">
                            <img src="@product.ImageUrl" onerror="this.src='https://placehold.co/150?text=Product';" />
                            <h6>@product.Name</h6>
                            <p>₱@product.Price</p>
                        </div>
                    }
                }
            </div>
        </div>
        <a href="/Home/Shop" class="Shop_Button">
            <h2>VIEW SHOP</h2>
        </a>
    </div>
</section>
        <div class="FeaturedImage_Container">
             <img src="/images/Home/FeaturedImage.jpg"/>
        </div>
        
    </div>
</section>