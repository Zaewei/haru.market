@model IEnumerable<haru.market.Models.ProductViewModel>
@{
    ViewData["Title"] = "Shop";
}

@section Styles {
    <link rel="stylesheet" href="~/css/costumer_page/Shop.css" />
    <style>
        /* Forces the image to animate smoothly when opacity changes */
        .rotating-image {
            transition: opacity 0.4s ease-in-out;
            opacity: 1;
        }
    </style>
}

<section class="ShopSection">
    <div class="Filter_Container">
        <div class="Filter_Button">
            <img src="~/images/Shop/Filter-icon.png" />
            <span>Filter & Sort</span>
        </div>
    </div>
    
    <div class="Product_Container">
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <div class="Product_Card">
                    <div class="Product_Image">
                        <img class="rotating-image" 
                             src="@product.ImageUrl" 
                             data-front="@product.ImageUrl" 
                             data-back="@product.Imageurl2" 
                             alt="@product.Name" 
                             onerror="this.src='https://placehold.co/300?text=Product+Image';" />
                    </div>

                    <div class="Product_ColorSeletor">
                        <div class="color-dot active">
                            <img src="/images/Shop/MyDarling/Icon/Black.png" />
                        </div>
                        <div class="color-dot active">
                            <img src="/images/Shop/MyDarling/Icon/White.png" />
                        </div>
                    </div>
                    
                    <h3>@product.Name</h3>
                    <p>₱@product.Price</p>
                </div>
            }
        }
        else
        {
            <div class="Product_Card">
                <div class="Product_Image">
                    <img src="~/images/Shop/MyDarling/Transparent/Black_Front.png" />
                </div>
                <div class="Product_ColorSeletor">
                    <div class="color-dot active">
                        <img src="/images/Shop/MyDarling/Icon/Black.png" />
                    </div>
                    <div class="color-dot active">
                        <img src="/images/Shop/MyDarling/Icon/White.png" />
                    </div>
                </div>
                <h3>My Darling</h3>
                <p>₱999</p>
            </div>
        }
    </div> 
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        
            const productImages = document.querySelectorAll('.rotating-image');

            let showingBackView = false;

            setInterval(() => {
                showingBackView = !showingBackView;

                productImages.forEach(img => {
                    const frontSrc = img.getAttribute('data-front');
                    const backSrc = img.getAttribute('data-back');

                    if (!backSrc || backSrc === "") return;

                    img.style.opacity = '0';

                    setTimeout(() => {
                        img.src = showingBackView ? backSrc : frontSrc;
                        img.style.opacity = '1';
                    }, 400);
                });
                
            }, 5000);
        });
    </script>
}