@model IEnumerable<haru.market.Models.ProductViewModel>
@{
    ViewData["Title"] = "Shop";
}

@section Styles {
    <link rel="stylesheet" href="~/css/costumer_page/Shop.css" />
    <style>
        .Product_Image {
            position: relative;
            overflow: hidden;
            border-radius: 12px;
            width: 100%;
        }

        .product-img-front {
            width: 100%;
            display: block;
            position: relative;
            z-index: 1;
            transition: opacity 0.3s ease-in-out, transform 0.4s ease-out;
        }

        .product-img-back {
            width: 100%;
            display: block;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 2;
            opacity: 0;
            transition: opacity 0.3s ease-in-out, transform 0.4s ease-out;
        }

        .Product_Card:hover .product-img-front {
            opacity: 0;
        }

        .Product_Card:hover .product-img-back {
            opacity: 1;
        }
        
        .Product_Card:hover .product-img-back,
        .Product_Card:hover .product-img-front {
            transform: scale(1.02);
        }
    </style>
}

<section class="ShopSection">
    <div class="Filter_Container">
        <div class="Filter_Button">
            <img src="~/images/Shop/Filter-icon.png" />
            <span>Filter & Sort</span>
        </div>
    </div>
    
    <div class="Product_Container">
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <div class="Product_Card">
                    <div class="Product_Image">
                        <img class="product-img-front" 
                             src="@product.ImageUrl" 
                             alt="@product.Name" 
                             onerror="this.src='https://placehold.co/300?text=Product+Image';" />

                        @if (!string.IsNullOrEmpty(product.Imageurl2))
                        {
                            <img class="product-img-back" 
                                 src="@product.Imageurl2" 
                                 alt="@product.Name side view" />
                        }
                    </div>

                    <div class="Product_ColorSeletor">
                        <div class="color-dot active">
                            <img src="/images/Shop/MyDarling/Icon/Black.png" />
                        </div>
                        <div class="color-dot active">
                            <img src="/images/Shop/MyDarling/Icon/White.png" />
                        </div>
                    </div>
                    
                    <h3>@product.Name</h3>
                    <p>₱@product.Price</p>
                </div>
            }
        }
        else
        {
            <div class="Product_Card">
                <div class="Product_Image">
                    <img src="~/images/Shop/MyDarling/Transparent/Black_Front.png" />
                </div>
                <div class="Product_ColorSeletor">
                    <div class="color-dot active">
                        <img src="/images/Shop/MyDarling/Icon/Black.png" />
                    </div>
                    <div class="color-dot active">
                        <img src="/images/Shop/MyDarling/Icon/White.png" />
                    </div>
                </div>
                <h3>My Darling</h3>
                <p>₱999</p>
            </div>
        }
    </div> 
</section>

@section Scripts {
}