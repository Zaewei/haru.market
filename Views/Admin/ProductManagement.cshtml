@model List<haru.market.Models.ProductViewModel>

@{
    ViewData["Title"] = "Product Management";
}

<link rel="stylesheet" href="~/css/admin/productmanagement.css" asp-append-version="true" />

<!-- ══ TABLE VIEW ══ -->
<div id="pmTableView">

    <div class="pm-header pm-header--center">
        <h1 class="pm-title-center">Product Management</h1>
    </div>

    <div class="pm-add-row">
        <button class="pm-add-top-btn" id="addProductBtn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
            Add New Product
        </button>
    </div>

    @if (TempData["PMError"] != null)
    {
        <div style="color:#c62828;font-family:'Poppins',sans-serif;font-size:0.88rem;margin-bottom:1rem;">
            ⚠ @TempData["PMError"]
        </div>
    }

    <div class="pm-table-card">
        <table class="pm-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Name</th>
                    <th>Color</th>
                    <th>Size</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="productTableBody">
                @if (Model != null && Model.Any())
                {
                    @foreach (var product in Model)
                    {
                        <tr class="pm-row" data-id="@product.Id">
                            <td>
                                <div class="pm-thumb-wrap">
                                    <div class="pm-thumb">
                                        @if (!string.IsNullOrEmpty(product.ImageUrl) && product.ImageUrl != "placeholder.png")
                                        {
                                            <img src="@product.ImageUrl" alt="@product.Name" />
                                        }
                                        else
                                        {
                                            <div class="pm-thumb-placeholder">No Image</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td><span class="pm-name">@product.Name</span></td>
                            <td><span class="pm-meta">@(string.IsNullOrEmpty(product.Color) ? "—" : product.Color)</span></td>
                            <td><span class="pm-meta">@(string.IsNullOrEmpty(product.Size) ? "—" : product.Size)</span></td>
                            <td><span class="pm-price">₱@product.Price.ToString("N0")</span></td>
                            <td><span class="pm-meta">@product.StockQuantity</span></td>
                            <td class="pm-actions pm-actions--stack">
                                <button class="btn-edit"   data-action="pm-edit"   data-id="@product.Id">Edit</button>
                                <button class="btn-delete" data-action="pm-delete" data-id="@product.Id">Delete</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr class="pm-row" data-id="p1"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">My Darling</span></td><td><span class="pm-meta">Black</span></td><td><span class="pm-meta">S</span></td><td><span class="pm-price">₱650</span></td><td><span class="pm-meta">10</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p1">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p1">Delete</button></td></tr>
                    <tr class="pm-row" data-id="p2"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">Everything Starts Anew</span></td><td><span class="pm-meta">Black</span></td><td><span class="pm-meta">L</span></td><td><span class="pm-price">₱650</span></td><td><span class="pm-meta">15</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p2">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p2">Delete</button></td></tr>
                    <tr class="pm-row" data-id="p3"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">HARUX3838</span></td><td><span class="pm-meta">White</span></td><td><span class="pm-meta">L</span></td><td><span class="pm-price">₱650</span></td><td><span class="pm-meta">15</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p3">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p3">Delete</button></td></tr>
                    <tr class="pm-row" data-id="p4"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">Pink White Collar</span></td><td><span class="pm-meta">Pink</span></td><td><span class="pm-meta">M</span></td><td><span class="pm-price">₱650</span></td><td><span class="pm-meta">20</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p4">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p4">Delete</button></td></tr>
                    <tr class="pm-row" data-id="p5"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">Cherry Blossom Tee</span></td><td><span class="pm-meta">Black</span></td><td><span class="pm-meta">XS</span></td><td><span class="pm-price">₱700</span></td><td><span class="pm-meta">8</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p5">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p5">Delete</button></td></tr>
                    <tr class="pm-row" data-id="p6"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">Sakura Puff Sleeve</span></td><td><span class="pm-meta">Pink</span></td><td><span class="pm-meta">S</span></td><td><span class="pm-price">₱750</span></td><td><span class="pm-meta">12</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p6">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p6">Delete</button></td></tr>
                    <tr class="pm-row" data-id="p7"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">Haru Classic White</span></td><td><span class="pm-meta">White</span></td><td><span class="pm-meta">M</span></td><td><span class="pm-price">₱650</span></td><td><span class="pm-meta">25</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p7">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p7">Delete</button></td></tr>
                    <tr class="pm-row" data-id="p8"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">Midnight Bloom</span></td><td><span class="pm-meta">Black</span></td><td><span class="pm-meta">XL</span></td><td><span class="pm-price">₱800</span></td><td><span class="pm-meta">5</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p8">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p8">Delete</button></td></tr>
                    <tr class="pm-row" data-id="p9"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">Rose Collar Crop</span></td><td><span class="pm-meta">Pink</span></td><td><span class="pm-meta">S</span></td><td><span class="pm-price">₱700</span></td><td><span class="pm-meta">18</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p9">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p9">Delete</button></td></tr>
                    <tr class="pm-row" data-id="p10"><td><div class="pm-thumb-wrap"><div class="pm-thumb pm-thumb-placeholder">No Image</div></div></td><td><span class="pm-name">Pearl Button Down</span></td><td><span class="pm-meta">White</span></td><td><span class="pm-meta">L</span></td><td><span class="pm-price">₱850</span></td><td><span class="pm-meta">7</span></td><td class="pm-actions pm-actions--stack"><button class="btn-edit" data-action="pm-edit" data-id="p10">Edit</button><button class="btn-delete" data-action="pm-delete" data-id="p10">Delete</button></td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="pm-pagination" id="pmPaginationBar"></div>

</div><!-- end #pmTableView -->


<!-- ══ INLINE EDIT PANEL ══ -->
<div id="pmEditPanel" style="display:none;">

    <div class="pm-edit-back-row">
        <button class="pm-edit-back-btn" id="pmEditBackBtn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="13" height="13"><polyline points="15 18 9 12 15 6"/></svg>
            Back
        </button>
    </div>

    <div class="pm-edit-layout">

        <!-- LEFT: image gallery (carousel + drag-and-drop) -->
        <div class="pm-edit-gallery">

            <!-- Main viewer with prev/next arrows -->
            <div class="pm-edit-main-img-wrap" id="pmEditMainWrap">
                <button class="pm-carousel-arrow pm-carousel-arrow--prev" id="pmCarouselPrev" type="button" aria-label="Previous image">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <img id="pmEditMainImg" src="" alt="Product" class="pm-edit-main-img" style="display:none;" />
                <div class="pm-edit-main-placeholder" id="pmEditMainPlaceholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#d4a8b2" stroke-width="1.5" width="36" height="36"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
                <button class="pm-carousel-arrow pm-carousel-arrow--next" id="pmCarouselNext" type="button" aria-label="Next image">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <!-- dot indicators -->
                <div class="pm-carousel-dots" id="pmCarouselDots"></div>
            </div>

            <!-- Drag-and-drop thumbnail strip -->
            <div class="pm-edit-thumbs" id="pmEditThumbs">
                <!-- thumbnails injected by JS -->
                <label class="pm-edit-thumb pm-edit-thumb--add" for="pmEditImageFile" id="pmThumbAddBtn" title="Add image">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </label>
                <input type="file" id="pmEditImageFile" accept="image/*" style="display:none;" multiple />
            </div>
        </div>

        <!-- RIGHT: fields -->
        <div class="pm-edit-fields">

            <div class="pm-edit-field-group">
                <label class="pm-edit-label">Product Name</label>
                <input type="text" class="pm-edit-input" id="pmEditName" />
            </div>

            <div class="pm-edit-field-group">
                <label class="pm-edit-label">Price</label>
                <div class="pm-edit-price-wrap">
                    <span class="pm-edit-price-prefix">₱</span>
                    <input type="number" class="pm-edit-input pm-edit-input--price" id="pmEditPrice" />
                </div>
            </div>

            <div class="pm-edit-field-group">
                <label class="pm-edit-label">Available Colors</label>
                <div class="pm-edit-colors">
                    <div class="pm-edit-color pm-edit-color--black" data-color="Black" title="Black"><span class="pm-color-remove-x" data-action="pm-color-remove">&times;</span></div>
                    <div class="pm-edit-color pm-edit-color--white" data-color="White" title="White"><span class="pm-color-remove-x" data-action="pm-color-remove">&times;</span></div>
                    <div class="pm-edit-color pm-edit-color--pink"  data-color="Pink"  title="Pink"><span class="pm-color-remove-x" data-action="pm-color-remove">&times;</span></div>
                    <button class="pm-edit-color-add" type="button" title="Add color">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    </button>
                    <input type="color" id="pmColorPickerInput" value="#c96a7f" style="display:none;" />
                </div>

                <!-- Confirm popover for removing a color -->
                <div class="pm-color-confirm-popover" id="pmColorRemoveConfirmPopover" style="display:none;">
                    <span class="pm-color-preview-hex">Remove this color?</span>
                    <button type="button" class="pm-color-confirm-btn pm-color-confirm-btn--danger" id="pmColorRemoveConfirmBtn">Remove</button>
                    <button type="button" class="pm-color-cancel-btn" id="pmColorRemoveCancelBtn">Cancel</button>
                </div>

                <!-- Confirm popover for newly picked color -->
                <div class="pm-color-confirm-popover" id="pmColorConfirmPopover" style="display:none;">
                    <span class="pm-color-preview-dot" id="pmColorPreviewDot"></span>
                    <span class="pm-color-preview-hex" id="pmColorPreviewHex">#c96a7f</span>
                    <button type="button" class="pm-color-confirm-btn" id="pmColorConfirmBtn">Add</button>
                    <button type="button" class="pm-color-cancel-btn" id="pmColorCancelBtn">Cancel</button>
                </div>
            </div>

            <div class="pm-edit-field-group">
                <div class="pm-edit-size-header">
                    <span class="pm-edit-col-label">Sizes</span>
                    <span class="pm-edit-col-label">Stock</span>
                </div>
                <div class="pm-edit-size-rows">
                    <div class="pm-edit-size-row"><span class="pm-edit-size-name">S</span><div class="pm-edit-stock-ctrl"><button type="button" class="pm-stock-btn" data-dir="-1" data-size="S">−</button><span class="pm-stock-val" id="pmStock-S">15</span><button type="button" class="pm-stock-btn" data-dir="1" data-size="S">+</button></div></div>
                    <div class="pm-edit-size-row"><span class="pm-edit-size-name">M</span><div class="pm-edit-stock-ctrl"><button type="button" class="pm-stock-btn" data-dir="-1" data-size="M">−</button><span class="pm-stock-val" id="pmStock-M">12</span><button type="button" class="pm-stock-btn" data-dir="1" data-size="M">+</button></div></div>
                    <div class="pm-edit-size-row"><span class="pm-edit-size-name">L</span><div class="pm-edit-stock-ctrl"><button type="button" class="pm-stock-btn" data-dir="-1" data-size="L">−</button><span class="pm-stock-val" id="pmStock-L">13</span><button type="button" class="pm-stock-btn" data-dir="1" data-size="L">+</button></div></div>
                    <div class="pm-edit-size-row"><span class="pm-edit-size-name">XL</span><div class="pm-edit-stock-ctrl"><button type="button" class="pm-stock-btn" data-dir="-1" data-size="XL">−</button><span class="pm-stock-val" id="pmStock-XL">15</span><button type="button" class="pm-stock-btn" data-dir="1" data-size="XL">+</button></div></div>
                    <div class="pm-edit-size-row"><span class="pm-edit-size-name">XXL</span><div class="pm-edit-stock-ctrl"><button type="button" class="pm-stock-btn" data-dir="-1" data-size="XXL">−</button><span class="pm-stock-val" id="pmStock-XXL">15</span><button type="button" class="pm-stock-btn" data-dir="1" data-size="XXL">+</button></div></div>
                </div>
            </div>

            <button class="pm-edit-save-btn" id="pmEditSaveBtn">Save Changes</button>

            <!-- Remove current photo -->
            <button class="pm-remove-photo-btn" id="pmRemovePhotoBtn" type="button" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                Remove Photo
            </button>

        </div>
    </div>
</div>


<!-- ══ ADD PRODUCT MODAL ══ -->
<div class="pm-modal-overlay" id="addProductModal" style="display:none;">
    <div class="pm-modal">
        <div class="pm-modal-header">
            <h2>Add Product</h2>
            <button class="pm-modal-close" type="button" onclick="document.getElementById('addProductModal').style.display='none'">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" width="18" height="18">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <form asp-controller="Admin" asp-action="AddProduct" method="post">
            <div class="pm-modal-body">
                <div class="pm-form-row">
                    <div class="pm-form-group">
                        <label class="form-label">Product Name *</label>
                        <input class="form-input" name="Name" type="text" placeholder="e.g. My Darling" required />
                    </div>
                    <div class="pm-form-group">
                        <label class="form-label">Price (₱) *</label>
                        <input class="form-input" name="Price" type="number" step="0.01" min="0.01" placeholder="650" required />
                    </div>
                </div>
                <div class="pm-form-row">
                    <div class="pm-form-group">
                        <label class="form-label">Color</label>
                        <input class="form-input" name="Color" type="text" placeholder="e.g. Black" />
                    </div>
                    <div class="pm-form-group">
                        <label class="form-label">Size</label>
                        <select class="form-input" name="Size">
                            <option value="">— Select Size —</option>
                            <option value="XS">XS</option>
                            <option value="S">S</option>
                            <option value="M">M</option>
                            <option value="L">L</option>
                            <option value="XL">XL</option>
                            <option value="XXL">XXL</option>
                        </select>
                    </div>
                </div>
                <div class="pm-form-group">
                    <label class="form-label">Product Image</label>
                    <div class="pm-image-upload-area" id="addImageUploadArea">
                        <div class="pm-image-placeholder" id="addImagePlaceholder">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#c96a7f" stroke-width="1.5" width="28" height="28"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                            <span>Click or drag to upload image</span>
                        </div>
                        <img id="addPreviewImage" class="pm-preview-img" src="" alt="Preview" style="display:none;" />
                    </div>
                    <input type="file" id="addProductImageFile" accept="image/*" style="display:none;" />
                    <input type="hidden" name="ImageUrl" id="addImageUrlHidden" />
                </div>
                <div class="pm-form-row">
                    <div class="pm-form-group">
                        <label class="form-label">Stock Quantity *</label>
                        <input class="form-input" name="StockQuantity" type="number" min="0" placeholder="10" required />
                    </div>
                </div>
                <div class="pm-form-group">
                    <label class="form-label">Description</label>
                    <textarea class="form-input" name="Description" rows="3" placeholder="Product description..." style="resize:vertical;"></textarea>
                </div>
            </div>
            <div class="pm-modal-footer">
                <button type="button" class="pm-btn-cancel" onclick="document.getElementById('addProductModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-create">Add Product</button>
            </div>
        </form>
    </div>
</div>


<!-- ══ DELETE CONFIRM MODAL ══ -->
<div class="pm-modal-overlay" id="deleteProductModal" style="display:none;">
    <div class="pm-modal pm-modal-sm">
        <div class="pm-modal-header">
            <h2>Delete Product</h2>
            <button class="pm-modal-close" id="closeDeleteProductModal" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" width="18" height="18">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <div class="pm-modal-body">
            <p class="pm-delete-msg">
                Are you sure you want to delete <strong id="deleteProductName"></strong>?
                This action cannot be undone.
            </p>
        </div>
        <div class="pm-modal-footer">
            <button type="button" class="pm-btn-cancel" id="cancelDeleteProduct">Cancel</button>
            <button type="button" class="pm-btn-confirm-delete" id="confirmDeleteProduct">Delete</button>
        </div>
    </div>
</div>
