<!-- ═══════════════════════════════════════════
     ADD / EDIT PRODUCT MODAL
═══════════════════════════════════════════ -->
<div class="pm-modal-overlay" id="productModal" style="display:none;">
    <div class="pm-modal">
        <div class="pm-modal-header">
            <h2 id="productModalTitle">Add Product</h2>
            <button class="pm-modal-close" id="closeProductModal" aria-label="Close">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <div class="pm-modal-body">
            <!-- Image Upload -->
            <div class="pm-form-group">
                <label class="form-label">Product Image</label>
                <div class="pm-image-upload-area" id="imageUploadArea">
                    <div class="pm-image-placeholder" id="imagePlaceholder">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#c96a7f" stroke-width="1.5" width="32" height="32"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                        <span>Click to upload image</span>
                        <span class="pm-upload-hint">JPG, PNG, WEBP — max 5MB</span>
                    </div>
                    <img id="previewImage" class="pm-preview-img" src="" alt="Preview" style="display:none;" />
                </div>
                <input type="file" id="productImageFile" accept="image/*" style="display:none;" />
                <div class="pm-image-actions" id="imageActions" style="display:none;">
                    <button class="btn-edit" id="changeImageBtn" type="button">Change</button>
                    <button class="btn-delete" id="removeImageBtn" type="button">Remove</button>
                </div>
            </div>

            <!-- Name -->
            <div class="pm-form-group">
                <label class="form-label" for="productName">Product Name</label>
                <input type="text" id="productName" class="form-input" placeholder="e.g. My Darling" />
            </div>

            <!-- Color & Size (side by side) -->
            <div class="pm-form-row">
                <div class="pm-form-group">
                    <label class="form-label" for="productColor">Color</label>
                    <input type="text" id="productColor" class="form-input" placeholder="e.g. Black" />
                </div>
                <div class="pm-form-group">
                    <label class="form-label" for="productSize">Size</label>
                    <select id="productSize" class="form-input dash-select" style="padding:8px 12px;">
                        <option value="">Select size</option>
                        <option value="XS">XS</option>
                        <option value="S">S</option>
                        <option value="M">M</option>
                        <option value="L">L</option>
                        <option value="XL">XL</option>
                        <option value="XXL">XXL</option>
                    </select>
                </div>
            </div>

            <!-- Price & Stock (side by side) -->
            <div class="pm-form-row">
                <div class="pm-form-group">
                    <label class="form-label" for="productPrice">Price (₱)</label>
                    <input type="number" id="productPrice" class="form-input" placeholder="e.g. 650" min="0" step="0.01" />
                </div>
                <div class="pm-form-group">
                    <label class="form-label" for="productStock">Available Stock</label>
                    <input type="number" id="productStock" class="form-input" placeholder="e.g. 10" min="0" step="1" />
                </div>
            </div>
        </div>

        <div class="pm-modal-footer">
            <button class="pm-btn-confirm-delete" id="modalDeleteBtn" type="button" style="display:none;margin-right:auto;">Delete</button>
            <button class="pm-btn-cancel" id="cancelProductModal" type="button">Cancel</button>
            <button class="btn-create" id="saveProductBtn" type="button">Save Product</button>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════
     DELETE CONFIRM MODAL
═══════════════════════════════════════════ -->
<div class="pm-modal-overlay" id="deleteProductModal" style="display:none;">
    <div class="pm-modal pm-modal-sm">
        <div class="pm-modal-header">
            <h2>Delete Product</h2>
            <button class="pm-modal-close" id="closeDeleteProductModal" aria-label="Close">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="pm-modal-body">
            <p class="pm-delete-msg">Are you sure you want to delete <strong id="deleteProductName"></strong>? This action cannot be undone.</p>
        </div>
        <div class="pm-modal-footer">
            <button class="pm-btn-cancel" id="cancelDeleteProduct" type="button">Cancel</button>
            <button class="btn-delete pm-btn-confirm-delete" id="confirmDeleteProduct" type="button">Delete</button>
        </div>
    </div>
</div>


