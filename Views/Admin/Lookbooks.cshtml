@model IEnumerable<haru.market.Models.LookbookViewModel>
@{
    ViewData["Title"] = "Lookbooks";
    var lookbookList = Model?.ToList() ?? new List<haru.market.Models.LookbookViewModel>();
    var featured = lookbookList.FirstOrDefault();
    var rest = lookbookList.Skip(1).ToList();
}

<link rel="stylesheet" href="~/css/admin/lookbooks.css" asp-append-version="true" />

@Html.AntiForgeryToken()

<div class="haru-admin-container">

    <div class="haru-header">
        <h2 class="haru-header-title">Lookbooks Management</h2>
        <div class="haru-header-actions">
            <a href="/Home/Lookbook" target="_blank" class="haru-btn-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                Preview Storefront
            </a>
            <button class="haru-btn-primary" onclick="openInlineCreator()">+ Create New Lookbook</button>
        </div>
    </div>

    <div id="featured-card-top" class="haru-card">
        @if (featured != null)
        {
            <div class="haru-flex-layout">
                
                <div class="haru-featured-img-wrap">
                    <img src="@featured.MediaUrl" alt="Cover" class="lb-cover-img" />
                </div>

                <div class="haru-featured-info">
                    <div class="lb-draft-name-row">
                        <span class="lb-badge-draft" style="background: #e2f0d9; color: #385723; padding: 4px 12px; border-radius: 4px; font-size: 11px; font-weight: bold; text-transform: uppercase;">Active Headline</span>
                    </div>
                    <h3 class="haru-featured-title">@featured.ThemeTitle</h3>
                    <p class="haru-featured-desc">@featured.Description</p>
                    
                    <div class="haru-action-row">
                        <button class="haru-btn-danger" onclick="triggerCustomDeleteModal('@featured.Id', 'featured-card-top', true)">Delete Campaign</button>
                    </div>
                </div>

            </div>
        }
        else
        {
            <div class="lb-cover-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <h4>No Live Campaigns Set</h4>
                <p>Open the creation workspace below to broadcast your first clothing collection catalog.</p>
            </div>
        }
    </div>

    <div class="haru-card" id="lbCreateCard" style="display: none; border-style: dashed; background-color: #fff5f7;">
        <div class="haru-creator-layout">
            
            <div id="inlinePreviewContainer" class="haru-preview-box">
                <img id="inlinePreviewImg" src="" class="lb-cover-img" style="display: none;" />
                <div id="inlinePreviewPlaceholder">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <div>No Link</div>
                </div>
            </div>

            <div class="haru-fields-vertical">
                <input type="text" id="newLbTitle" placeholder="Lookbook Collection Title" class="haru-creator-title-input" />
                <textarea id="newLbDesc" rows="3" placeholder="Write this lookbook's core style narrative description..." class="haru-creator-textarea"></textarea>
                <input type="url" id="newLbMedia" placeholder="Paste your direct image URL link asset path here..." oninput="updateInlinePreview(this.value)" class="haru-creator-url-input" />
                
                <div class="haru-header-actions">
                    <button type="button" class="haru-btn-outline" onclick="closeInlineCreator()">Cancel</button>
                    <button type="button" class="haru-btn-primary" onclick="submitInlineCardForm()">Publish Collection</button>
                </div>
            </div>

        </div>
    </div>

    <div class="lb-create-row" id="createRowTrigger">
        <button class="lb-btn-create" onclick="openInlineCreator()">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            Open Lookbook Creation Deck
        </button>
    </div>

    <div class="lb-drafts-section">
        <h4 class="haru-history-title">Archive Collection History</h4>

        <div id="history-grid-list">
            @if (rest.Any())
            {
                @foreach (var lb in rest)
                {
                    <div id="history-item-@lb.Id" class="haru-history-card">
                        <div class="haru-history-thumb">
                            <img src="@lb.MediaUrl" alt="Thumb" class="lb-cover-img" />
                        </div>

                       <div class="haru-history-split-row">
                            <div>
                                <div class="lb-draft-name-row">
                                    <span class="lb-draft-name lb-list-name">@lb.ThemeTitle</span>
                                    <span class="lb-badge-draft">ARCHIVED</span>
                                </div>
                                <p class="haru-featured-desc" style="margin: 0; font-size: 13px;">@lb.Description</p>
                            </div>
                            <div style="display: flex; gap: 8px;">
                                <button class="haru-btn-outline" onclick="setFeaturedDirect('@lb.Id')" style="padding: 6px 12px; font-size: 12px;">Set Featured</button>
                                <button class="haru-btn-danger" onclick="triggerCustomDeleteModal('@lb.Id', 'history-item-@lb.Id', false)">Delete</button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="lb-draft-main-empty" id="historyEmptyPlaceholder">
                    No older campaigns stored in chronological catalog data logs.
                </div>
            }
        </div>
    </div>

</div>

<div class="haru-modal-overlay" id="haruDeleteModal">
    <div class="haru-modal">
        <div style="color: #bd3a54; margin-bottom: 15px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><circle cx="12" cy="17" r="1"/></svg>
        </div>
        <h3 class="haru-history-title" style="border: none; margin-bottom: 10px; margin-top: 0;">Delete Campaign?</h3>
        <p class="haru-featured-desc" style="color: #666; font-size: 14px;">Are you sure you want to delete this lookbook? This will permanently erase the document record from your live Firestore database collections.</p>
        
        <div class="haru-header-actions" style="justify-content: center;">
            <button class="haru-btn-outline" onclick="closeCustomDeleteModal()">Cancel</button>
            <button class="haru-btn-primary" id="confirmDeleteBtn" style="background: #bd3a54;">Confirm Delete</button>
        </div>
    </div>
</div>

<script>
    let activeDeleteId = null;
    let activeDomId = null;
    let activeIsFeatured = false;

    function openInlineCreator() {
        document.getElementById('lbCreateCard').style.display = 'block';
        document.getElementById('createRowTrigger').style.display = 'none';
    }

    function closeInlineCreator() {
        document.getElementById('lbCreateCard').style.display = 'none';
        document.getElementById('createRowTrigger').style.display = 'block';
        document.getElementById('newLbTitle').value = '';
        document.getElementById('newLbDesc').value = '';
        document.getElementById('newLbMedia').value = '';
        updateInlinePreview('');
    }

    function updateInlinePreview(url) {
        const img = document.getElementById('inlinePreviewImg');
        const placeholder = document.getElementById('inlinePreviewPlaceholder');
        if (url && (url.startsWith('http://') || url.startsWith('https://'))) {
            img.src = url;
            img.style.display = 'block';
            placeholder.style.display = 'none';
        } else {
            img.src = '';
            img.style.display = 'none';
            placeholder.style.display = 'block';
        }
    }

    function triggerCustomDeleteModal(id, domElementId, isFeatured) {
        activeDeleteId = id;
        activeDomId = domElementId;
        activeIsFeatured = isFeatured;
        document.getElementById('haruDeleteModal').style.display = 'flex';
    }

    function closeCustomDeleteModal() {
        document.getElementById('haruDeleteModal').style.display = 'none';
        activeDeleteId = null;
        activeDomId = null;
        activeIsFeatured = false;
    }

    async function submitInlineCardForm() {
        const title = document.getElementById('newLbTitle').value.trim();
        const desc = document.getElementById('newLbDesc').value.trim();
        const media = document.getElementById('newLbMedia').value.trim();
        
        if (!title || !desc || !media) {
            alert("Please fill out Title, Description, and Link URL before publishing.");
            return;
        }

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        
        const params = new URLSearchParams();
        params.append("ThemeTitle", title);
        params.append("Description", desc);
        params.append("MediaUrl", media);
        params.append("__RequestVerificationToken", token);

        try {
            const response = await fetch('/Admin/UploadLookbook', {
                method: 'POST',
                body: params,
                headers: {
                    'RequestVerificationToken': token
                }
            });

            const result = await response.json();
            if (result.success) {
                closeInlineCreator();
                
                const featuredContainer = document.getElementById('featured-card-top');
                const isPlaceholderActive = featuredContainer.querySelector('.lb-cover-placeholder');

                if (isPlaceholderActive || !featuredContainer.querySelector('.haru-flex-layout')) {
                    featuredContainer.innerHTML = `
                        <div class="haru-flex-layout">
                            <div class="haru-featured-img-wrap">
                                <img src="${result.mediaUrl}" alt="Cover" class="lb-cover-img" />
                            </div>
                            <div class="haru-featured-info">
                                <div class="lb-draft-name-row">
                                    <span class="lb-badge-draft" style="background: #e2f0d9; color: #385723; padding: 4px 12px; border-radius: 4px; font-size: 11px; font-weight: bold; text-transform: uppercase;">Active Headline</span>
                                </div>
                                <h3 class="haru-featured-title">${result.themeTitle}</h3>
                                <p class="haru-featured-desc">${result.description}</p>
                                <div class="haru-action-row">
                                    <button class="haru-btn-danger" onclick="triggerCustomDeleteModal('${result.id}', 'featured-card-top', true)">Delete Campaign</button>
                                </div>
                            </div>
                        </div>
                    `;
                } else {
                    const gridList = document.getElementById('history-grid-list');
                    const emptyText = document.getElementById('historyEmptyPlaceholder');
                    if (emptyText) emptyText.remove();

                    const newCard = document.createElement('div');
                    newCard.id = `history-item-${result.id}`;
                    newCard.className = 'haru-history-card';
                    newCard.innerHTML = `
                        <div class="haru-history-thumb">
                            <img src="${result.mediaUrl}" alt="Thumb" class="lb-cover-img" />
                        </div>
                        <div class="haru-history-split-row">
                            <div>
                                <div class="lb-draft-name-row">
                                    <span class="lb-draft-name lb-list-name">${result.themeTitle}</span>
                                    <span class="lb-badge-draft">ARCHIVED</span>
                                </div>
                                <p class="haru-featured-desc" style="margin: 0; font-size: 13px;">${result.description}</p>
                            </div>
                            <button class="haru-btn-danger" onclick="triggerCustomDeleteModal('${result.id}', 'history-item-${result.id}', false)">Delete</button>
                        </div>
                    `;
                    gridList.insertBefore(newCard, gridList.firstChild);
                }
            } else {
                alert("Upload failed: " + result.message);
            }
        } catch (error) {
            console.error("AJAX Error:", error);
            alert("Network connection error trying to publish lookbook.");
        }
    }

    document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
        if (!activeDeleteId) return;

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const params = new URLSearchParams();
        params.append("id", activeDeleteId);
        params.append("__RequestVerificationToken", token);

        closeCustomDeleteModal();

        try {
            const response = await fetch('/Admin/DeleteLookbook', {
                method: 'POST',
                body: params,
                headers: {
                    'RequestVerificationToken': token
                }
            });

            const result = await response.json();
            if (result.success) {
                if (activeIsFeatured) {
                    const gridList = document.getElementById('history-grid-list');
                    const firstArchive = gridList ? gridList.firstElementChild : null;

                    if (firstArchive && !firstArchive.classList.contains('lb-draft-main-empty')) {
                        const nextId = firstArchive.id.replace('history-item-', '');
                        const nextTitle = firstArchive.querySelector('.lb-list-name').innerText;
                        const nextDesc = firstArchive.querySelector('.haru-featured-desc').innerText;
                        const nextImgSrc = firstArchive.querySelector('.lb-cover-img').src;

                        firstArchive.remove();
                        checkArchiveEmpty();

                        document.getElementById('featured-card-top').innerHTML = `
                            <div class="haru-flex-layout">
                                <div class="haru-featured-img-wrap">
                                    <img src="${nextImgSrc}" alt="Cover" class="lb-cover-img" />
                                </div>
                                <div class="haru-featured-info">
                                    <div class="lb-draft-name-row">
                                        <span class="lb-badge-draft" style="background: #e2f0d9; color: #385723; padding: 4px 12px; border-radius: 4px; font-size: 11px; font-weight: bold; text-transform: uppercase;">Active Headline</span>
                                    </div>
                                    <h3 class="haru-featured-title">${nextTitle}</h3>
                                    <p class="haru-featured-desc">${nextDesc}</p>
                                    <div class="haru-action-row">
                                        <button class="haru-btn-danger" onclick="triggerCustomDeleteModal('${nextId}', 'featured-card-top', true)">Delete Campaign</button>
                                    </div>
                                </div>
                            </div>
                        `;
                    } else {
                        document.getElementById('featured-card-top').innerHTML = `
                            <div class="lb-cover-placeholder">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                <h4>No Live Campaigns Set</h4>
                                <p>Open the creation workspace below to broadcast your first clothing collection catalog.</p>
                            </div>
                        `;
                    }
                } else {
                    const element = document.getElementById(activeDomId);
                    if (element) {
                        element.style.transition = "all 0.25s ease-out";
                        element.style.opacity = "0";
                        element.style.transform = "translateX(30px)";
                        setTimeout(() => {
                            element.remove();
                            checkArchiveEmpty();
                        }, 250);
                    }
                }
            } else {
                alert("Firestore failure message context: " + result.message);
            }
        } catch (error) {
            console.error("AJAX Error:", error);
            alert("Network link error trying to execute removal rules.");
        }
    });

    function checkArchiveEmpty() {
        const gridList = document.getElementById('history-grid-list');
        if (gridList && gridList.children.length === 0) {
            gridList.innerHTML = `
                <div class="lb-draft-main-empty" id="historyEmptyPlaceholder">
                    No older campaigns stored in chronological catalog data logs.
                </div>
            `;
        }
    }

    async function setFeaturedDirect(id) {
        if (!id) return;

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const params = new URLSearchParams();
        params.append("id", id);
        params.append("__RequestVerificationToken", token);

        try {
            const response = await fetch('/Admin/SetFeatured', {
                method: 'POST',
                body: params,
                headers: { 'RequestVerificationToken': token }
            });

            const result = await response.json();
            if (result.success) {
                location.reload();
            } else {
                alert("Featured assignment error: " + result.message);
            }
        } catch (error) {
            console.error("AJAX Error:", error);
            alert("Network connection error handling featured promotion.");
        }
    }
</script>