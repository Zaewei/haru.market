@model haru.market.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/admin/dashboard.css" asp-append-version="true" />

<div class="dash-header">
    <h1>Dashboard</h1>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
        <div class="stat-label">Total Lookbooks</div>
        <div class="stat-value">@Model.TotalLookbooks</div>
        <div class="stat-change up">↑ 0% vs. last month</div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        </div>
        <div class="stat-label">Total Products</div>
        <div class="stat-value">@Model.TotalProducts</div>
        <div class="stat-change up">↑ 0% vs. last month</div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        </div>
        <div class="stat-label">Total Users</div>
        <div class="stat-value">@Model.TotalUsers</div>
        <div class="stat-change up">↑ 0% vs. last month</div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <div class="stat-label">Total Views</div>
        <div class="stat-value">@Model.TotalViews.ToString("N0")</div>
        <div class="stat-change up">↑ 0% vs. last month</div>
    </div>
</div>

<div class="dash-row" style="margin-bottom:1rem;">

    <div class="dash-card">
        <h2>
            Lookbook Views
            <select class="dash-select">
                <option>This Month</option>
                <option>Last Month</option>
            </select>
        </h2>
        <div class="chart-container" style="position: relative; height: 220px; width: 100%;">
            <canvas id="viewsChart" 
                    data-labels='@Json.Serialize(ViewData["ChartLabels"])' 
                    data-values='@Json.Serialize(ViewData["ChartData"])'>
            </canvas>
        </div>
    </div>

    <div class="dash-card">
        <h2>
            Top Lookbooks
            <select class="dash-select">
                <option>This Month</option>
                <option>Last Month</option>
            </select>
        </h2>
        
        @{
            var topLookbooks = ViewData["TopLookbooks"] as List<haru.market.Models.LookbookViewModel>;
        }
        @if (topLookbooks != null && topLookbooks.Any())
        {
            foreach (var item in topLookbooks)
            {
                <div class="top-lookbook-item">
                    <div class="top-lookbook-thumb" style="background-image: url('@item.MediaUrl'); background-size: cover; background-position: center;"></div>
                    <div class="top-lookbook-info">
                        <div class="top-lookbook-title">@item.ThemeTitle</div>
                        <div class="top-lookbook-views">0 views</div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="text-align: center; padding: 2rem; color: #a0a0a0;">No campaign records available.</div>
        }
    </div>

</div>

<div class="dash-row" style="margin-bottom:1rem;">

    <div class="dash-card">
        <h2>
            Recent Lookbooks
            <a class="btn-create" asp-controller="Admin" asp-action="Lookbooks">+ Create New</a>
        </h2>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Lookbook Title</th>
                    <th>Status</th>
                    <th>Updated At</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.RecentLookbooks != null && Model.RecentLookbooks.Any())
                {
                    foreach (var item in Model.RecentLookbooks)
                    {
                        <tr>
                            <td>
                                <div class="table-thumb-row">
                                    <div class="table-thumb" style="background-image: url('@item.MediaUrl'); background-size: cover; background-position: center;"></div>
                                    @item.ThemeTitle
                                </div>
                            </td>
                            <td><span class="badge-published">Published</span></td>
                            <td>@item.CreatedAt.ToString("MMM d, yyyy")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" style="text-align: center; padding: 2rem; color: #a0a0a0;">No lookbooks found in database records.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="dash-card">
        <h2>Recent Activity</h2>
        
        @{
            var activities = new List<dynamic>();

            if (Model.RecentLookbooks != null)
            {
                activities.AddRange(Model.RecentLookbooks.Select(l => new {
                    Title = l.ThemeTitle,
                    Type = "Lookbook",
                    Date = l.CreatedAt,
                    IconClass = "activity-icon--publish",
                    Message = $"New Lookbook \"<strong>{l.ThemeTitle}</strong>\" was published."
                }));
            }

            if (Model.RecentProducts != null)
            {
                activities.AddRange(Model.RecentProducts.Select(p => new {
                    Title = p.Name, 
                    Type = "Product",
                    Date = p.CreatedAt, 
                    IconClass = "activity-icon--edit",
                    Message = $"Product \"<strong>{p.Name}</strong>\" was added to inventory."
                }));
            }

            var chronologicalFeed = activities.OrderByDescending(a => a.Date).Take(20).ToList();
        }

        <div class="activity-scroll-container" style="max-height: 280px; overflow-y: auto; padding-right: 0.5rem;">
            @if (chronologicalFeed.Any())
            {
                foreach (var activity in chronologicalFeed)
                {
                    <div class="activity-item">
                        <div class="activity-icon @activity.IconClass">
                            @if (activity.Type == "Lookbook")
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2">
                                    <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2">
                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>
                                </svg>
                            }
                        </div>
                        <div>
                            <div>@Html.Raw(activity.Message)</div>
                            <div class="activity-time">@activity.Date.ToString("MMM d, yyyy") · Admin</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 2rem; color: #a0a0a0;">No recent system activity logged.</div>
            }
        </div> 
    </div>

</div>

<div class="dash-row">

    <div class="dash-card">
        <h2>
            Top Collections
            <select class="dash-select">
                <option>This Month</option>
                <option>Last Month</option>
            </select>
        </h2>
        <div class="collection-item">
            <div class="collection-thumb"></div>
            <div class="collection-info">
                <div class="collection-name">Collection Name</div>
                <div class="collection-bar-wrap">
                    <div class="collection-bar" style="width:42%"></div>
                </div>
            </div>
            <div class="collection-pct">42%</div>
        </div>
        <div class="collection-item">
            <div class="collection-thumb"></div>
            <div class="collection-info">
                <div class="collection-name">Collection Name</div>
                <div class="collection-bar-wrap">
                    <div class="collection-bar" style="width:28%"></div>
                </div>
            </div>
            <div class="collection-pct">28%</div>
        </div>
    </div>

    <div class="dash-card">
        <h2>
            Users Overview
            <select class="dash-select">
                <option>This Month</option>
                <option>Last Month</option>
            </select>
        </h2>
        <div class="users-overview">
            <div class="donut-wrap">
                <div style="position: relative; height: 140px; width: 140px;">
                    <canvas id="usersChart" data-total-users='@Model.TotalUsers'></canvas>
                </div>
                <div class="donut-center">
                    <div class="donut-total">@Model.TotalUsers</div>
                    <div class="donut-label">Total Users</div>
                </div>
            </div>
            <div class="users-legend">
                <div class="legend-item">
                    <span class="legend-dot" style="background:#c96a7f"></span>
                    <span class="legend-text">New Users</span>
                    <span class="legend-val">@Model.TotalUsers (100%)</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot" style="background:#e8b4be"></span>
                    <span class="legend-text">Returning Users</span>
                    <span class="legend-val">0 (0%)</span>
                </div>
            </div>
        </div>
    </div>

</div>