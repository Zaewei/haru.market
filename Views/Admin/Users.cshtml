@{
    ViewData["Title"] = "Users";
}

<link rel="stylesheet" href="~/css/admin/users.css" asp-append-version="true" />

<div class="page-header">
    <h1>Users</h1>
</div>

<div class="usr-stat-grid">
    <div class="usr-stat-card">
        <div class="usr-stat-icon usr-stat-icon--total">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="usr-stat-label">Total Users</div>
        <div class="usr-stat-value" id="statTotalUsers">126</div>
    </div>
    <div class="usr-stat-card">
        <div class="usr-stat-icon usr-stat-icon--active">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="usr-stat-label">Active Users</div>
        <div class="usr-stat-value" id="statActiveUsers">110</div>
    </div>
    <div class="usr-stat-card">
        <div class="usr-stat-icon usr-stat-icon--new">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
        </div>
        <div class="usr-stat-label">New Users (This Month)</div>
        <div class="usr-stat-value" id="statNewUsers">26</div>
    </div>
    <div class="usr-stat-card">
        <div class="usr-stat-icon usr-stat-icon--inactive">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
        </div>
        <div class="usr-stat-label">Inactive Users</div>
        <div class="usr-stat-value" id="statInactiveUsers">16</div>
    </div>
</div>

<div class="usr-toolbar">
    <div class="usr-search-wrap">
        <svg class="usr-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="usr-search" id="usrSearch" type="text" placeholder="Search order ID, customer name, email…" />
    </div>
    <select class="usr-filter dash-select" id="roleFilter">
        <option value="">All Roles</option>
        <option value="admin">Admin</option>
        <option value="customer">Customer</option>
    </select>
    <div class="usr-date-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <select class="usr-filter dash-select" id="joinFilter">
            <option>Joined: All Time</option>
            <option>Joined: This Month</option>
            <option>Joined: This Year</option>
        </select>
    </div>
</div>

<div class="admin-card usr-table-card">
    <table class="data-table usr-table">
        <thead>
            <tr>
                <th>User</th>
                <th>Email</th>
                <th>Joined At</th>
                <th>Role</th>
                <th>Status</th>
                <th>Last Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="usersBody"></tbody>
    </table>
    <div class="usr-empty" id="usrEmpty" style="display:none;">No users match your filters.</div>
</div>

<div class="usr-pagination" id="usrPagination"></div>


<div class="usr-detail-overlay" id="userDetailOverlay">
    <div class="usr-detail-panel" id="userDetailPanel">

        <div class="usr-detail-breadcrumb">
            <button class="usr-detail-back" id="closeDetailBtn">Users</button>
            <span class="usr-detail-breadcrumb-sep">›</span>
            <span class="usr-detail-breadcrumb-cur">User details</span>
        </div>

        <div class="usr-overview-card" id="detailOverviewCard">
            <div class="usr-overview-header">
                <span class="usr-overview-title">Account Overview</span>
                <span class="usr-overview-status" id="detailStatus">Active</span>
            </div>

            <div class="usr-overview-grid">
                <div class="usr-info-col">
                    <div class="usr-info-col-title">Personal Information</div>
                    <div class="usr-info-row">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        <span id="detailName">—</span>
                    </div>
                    <div class="usr-info-row">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        <span id="detailEmail">—</span>
                    </div>
                    <div class="usr-info-row">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17z"/></svg>
                        <span id="detailPhone">—</span>
                    </div>
                    <div class="usr-info-row">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        <span id="detailAddress">—</span>
                    </div>
                    <div class="usr-info-row">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        <span id="detailJoined">—</span>
                    </div>
                </div>

                <div class="usr-info-col">
                    <div class="usr-info-col-title">Account Information</div>
                    <div class="usr-acct-row"><span class="usr-acct-label">User ID</span><span id="detailUserId">—</span></div>
                    <div class="usr-acct-row"><span class="usr-acct-label">Role</span><span id="detailRole">—</span></div>
                    <div class="usr-acct-row"><span class="usr-acct-label">Status</span><span id="detailStatusInline">—</span></div>
                    <div class="usr-acct-row"><span class="usr-acct-label">Last Active</span><span id="detailLastActive">—</span></div>
                    <div class="usr-acct-row"><span class="usr-acct-label">Password Change</span><span id="detailPwChange">—</span></div>
                </div>

                <div class="usr-info-col">
                    <div class="usr-info-col-title">Activity Summary</div>
                    <div class="usr-activity-row"><span>Orders</span><span id="detailOrders">—</span></div>
                    <div class="usr-activity-row"><span>Lookbooks Viewed</span><span id="detailLookbooks">—</span></div>
                    <div class="usr-activity-row"><span>Products Purchased</span><span id="detailProducts">—</span></div>
                    <div class="usr-activity-row"><span>Total Spent</span><span id="detailSpent" class="usr-activity-highlight">—</span></div>
                    <div class="usr-activity-row"><span>Wishlist Items</span><span id="detailWishlist">—</span></div>
                </div>
            </div>
        </div>

        <div class="usr-orders-section">
            <div class="usr-orders-header">
                <span class="usr-orders-title">Past Orders</span>
                <button class="usr-btn-view-all">View All Orders</button>
            </div>
            <div class="usr-orders-list" id="detailOrdersList">
                </div>
        </div>

        <button class="usr-btn-go-back" id="goBackBtn">Go back to user</button>

    </div>
</div>

<div class="ord-modal-overlay" id="usrOrderViewModal">
    <div class="ord-modal">
        <div class="ord-modal-header">
            <h2 id="usrOrderViewTitle">Order Details</h2>
            <button class="ord-modal-close" id="closeUsrOrderViewModal">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="ord-modal-body" id="usrOrderViewBody"></div>
        <div class="ord-modal-footer">
            <button class="pm-btn-cancel" id="closeUsrOrderViewFooter">Close</button>
        </div>
    </div>
</div>

@model IEnumerable<haru.market.Models.AdminUserViewModel>

<script>
    window.allUsers = @Json.Serialize(Model != null ? Model.Select(u => new {
    id = u.Id,
    name = u.Name,
    email = u.Email,
    joined = u.JoinedAt.ToString("MMM d, yyyy"),
    lastActive = u.LastActive.ToString("MMM d, yyyy, h:mm tt"),
    role = u.Role.ToLower(),
    status = u.Status.ToLower(),
    
    phone = u.Phone,
    address = u.Address,
    
    pwChange = "N/A",
    lookbooks = 0,
    products = 0,
    wishlist = 0
}) : new object[] {});
</script>

<script src="~/js/admin.js" asp-append-version="true"></script>
<script>
    function loadLiveUserStats(email) {
        document.getElementById('detailOrders').innerText = '...';
        document.getElementById('detailProducts').innerText = '...';
        document.getElementById('detailSpent').innerText = '...';
        document.getElementById('detailOrdersList').innerHTML = '<p style="color: #888; padding: 10px 0;">Loading orders...</p>';

        fetch('/Admin/GetUserStats?email=' + encodeURIComponent(email))
            .then(response => response.json())
            .then(data => {
                document.getElementById('detailOrders').innerText = data.totalOrders;
                document.getElementById('detailProducts').innerText = data.productsPurchased;
                document.getElementById('detailSpent').innerText = '₱' + data.totalSpent.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

                const ordersContainer = document.getElementById('detailOrdersList');
                ordersContainer.innerHTML = '';
                if (data.recentOrders && data.recentOrders.length > 0) {
                    data.recentOrders.forEach(order => {
                        const orderDate = new Date(order.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                        
                        const orderRow = `
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
                                <div>
                                    <strong style="color: #333;">#${order.id.substring(0, 8).toUpperCase()}</strong>
                                    <div style="color: #888; font-size: 13px; margin-top: 4px;">${orderDate}</div>
                                </div>
                                <div style="text-align: right;">
                                    <div style="font-weight: bold; color: #d63384;">₱${order.total.toLocaleString(undefined, { minimumFractionDigits: 2 })}</div>
                                    <div style="font-size: 12px; margin-top: 4px; padding: 2px 8px; border-radius: 12px; background: #eee; display: inline-block;">${order.status}</div>
                                </div>
                            </div>
                        `;
                        ordersContainer.innerHTML += orderRow;
                    });
                } else {
                    ordersContainer.innerHTML = '<p style="color: #888; padding: 10px 0;">No orders found for this user.</p>';
                }
            })
            .catch(err => {
                console.error("Error loading stats:", err);
                document.getElementById('detailOrders').innerText = '0';
                document.getElementById('detailProducts').innerText = '0';
                document.getElementById('detailSpent').innerText = '₱0.00';
                document.getElementById('detailOrdersList').innerHTML = '<p style="color: #888; padding: 10px 0;">Failed to load orders.</p>';
            });
    }

    document.addEventListener("DOMContentLoaded", () => {
        const emailField = document.getElementById('detailEmail');
        const overlay = document.getElementById('userDetailOverlay');
        
        if (emailField) {
            const observer = new MutationObserver((mutations) => {
                mutations.forEach((mutation) => {
                    const currentEmail = emailField.innerText.trim();
                    if (currentEmail && currentEmail !== '—') {
                        loadLiveUserStats(currentEmail);
                        
                        if (overlay) {
                            overlay.style.display = 'flex';
                        }
                    }
                });
            });

            observer.observe(emailField, { childList: true, characterData: true, subtree: true });
        }

        function closeUserModal() {
            if (overlay) {
                overlay.style.display = 'none';
            }
        }

        const topCloseBtn = document.getElementById('closeDetailBtn');
        const bottomCloseBtn = document.getElementById('goBackBtn');
        
        if (topCloseBtn) topCloseBtn.addEventListener('click', closeUserModal);
        if (bottomCloseBtn) bottomCloseBtn.addEventListener('click', closeUserModal);
    });
</script>