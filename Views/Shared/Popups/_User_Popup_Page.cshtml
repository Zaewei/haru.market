<div id="userPopup" class="User_Popup_Overlay" style="display: none;">
    <button id="closeUser" class="User_Exit_Window">&times;</button>
    
    <div class="User_Popup_Window">
        @if (User?.Identity?.IsAuthenticated == true)
        {
            <div class="User_Popup_Content">
                <button type="button" id="btnOpenProfile" class="haru-dropdown-btn"><p>My Profile</p></button>
            </div>
            <div class="User_Popup_Content">
                <button type="button" id="btnOpenLogout" class="haru-dropdown-btn"><p>Log Out</p></button>
            </div>
        }
        else
        {
            <div class="User_Popup_Content">
                <a href="/Account/Login"><p>Log In</p></a>
            </div>
            <div class="User_Popup_Content">
                <a href="/Account/Register"><p>Sign Up</p></a>
            </div>
        }
    </div>
</div>

@if (User?.Identity?.IsAuthenticated == true)
{
    <div id="logoutConfirmModal" class="haru-center-modal-overlay" style="display: none;">
        <div class="haru-center-modal-box">
            <button type="button" class="haru-modal-close-x" id="btnXLogout">&times;</button>
            <h4 class="haru-modal-title">Confirm Logout</h4>
            <p class="haru-modal-text">Are you sure you want to log out of <br><strong>@User.Identity?.Name</strong>?</p>
            
            <div class="haru-modal-actions">
                <button type="button" id="btnCancelLogout" class="haru-btn haru-btn-secondary">Cancel</button>
                <form method="post" action="/Account/Logout" style="margin: 0; width: 100%;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="haru-btn haru-btn-primary">Yes, Log Out</button>
                </form>
            </div>
        </div>
    </div>

    <div id="profileDetailsModal" class="haru-center-modal-overlay" style="display: none;">
        <div class="haru-center-modal-box">
            <button type="button" class="haru-modal-close-x" id="btnXProfile">&times;</button>
            <h4 class="haru-modal-title" id="profileModalTitle">My Profile</h4>
            
            <div id="profileViewSection">
                <div class="haru-profile-details">
                    <p><strong>Email:</strong> @User.Identity?.Name</p>
                    <p><strong>Full Name:</strong> <span id="lblFullName">Loading...</span></p>
                    <p><strong>Address:</strong> <span id="lblAddress">Loading...</span></p>
                    <p><strong>Contact:</strong> <span id="lblContact">Loading...</span></p>
                </div>
                <div class="haru-modal-actions">
                    <button type="button" id="btnCloseProfile" class="haru-btn haru-btn-secondary">Close</button>
                    <button type="button" id="btnEditProfile" class="haru-btn haru-btn-primary">Edit Details</button>
                </div>
            </div>

            <div id="profileEditSection" style="display: none;">
                <form id="editProfileForm">
                    <div class="haru-input-group">
                        <label>Full Name</label>
                        <input type="text" id="editFullName" name="FullName" class="haru-input" required />
                    </div>
                    <div class="haru-input-group">
                        <label>Delivery Address</label>
                        <input type="text" id="editAddress" name="DeliveryAddress" class="haru-input" required />
                    </div>
                    <div class="haru-input-group">
                        <label>Contact Details</label>
                        <input type="text" id="editContact" name="ContactDetails" class="haru-input" required />
                    </div>
                    <div class="haru-modal-actions" style="margin-top: 20px;">
                        <button type="button" id="btnCancelEdit" class="haru-btn haru-btn-secondary">Cancel</button>
                        <button type="submit" id="btnSaveProfile" class="haru-btn haru-btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="successModal" class="haru-center-modal-overlay" style="display: none;">
    <div class="haru-center-modal-box">
        <h4 class="haru-modal-title">Success!</h4>
        <p class="haru-modal-text" id="successMessage">Profile updated successfully.</p>
        <div class="haru-modal-actions">
            <button type="button" onclick="closeSuccessModal()" class="haru-btn haru-btn-primary">OK</button>
        </div>
    </div>
</div>
}