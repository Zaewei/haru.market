                                <img src="\images\Shop\MyDarling\Transparent\Black_Front.png" />
                            </div>
                            <div class="Bag_Product_Description ">
                                    <h3>(Product Name)</h3>
                                    <h5 class"Price">₱650</h5>
                                    <p>Size: (place here)</p>
                                    <p>(color)</p>
                            </div>
                            <div class="Bag_Product_Amount_Button ">
                                <div class="quantity">
                                    <button class="qty-minus">-</button>
                                        <span class="qty">1</span>
                                    <button class="qty-plus">+</button>
                                </div>
                            </div>
                            <div class="Bag_Product_Delete_Button">

                                <div class="Bag_Product_Delete_Button_container">
                                    <a href="#" class="delete-btn">
