<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HARU Admin</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/haru.market.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin/admin-base.css" asp-append-version="true" />

    <style>
    .admin-top-profile { 
        position: relative; 
        display: flex; 
        align-items: center; 
    }
    .admin-top-btn {
        background: none; border: none; cursor: pointer; padding: 0;
        display: flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; border-radius: 50%;
    }
    .admin-top-btn img {
        width: 24px; height: 24px; object-fit: contain;
    }
    header {
        position: relative;
        z-index: 2000 !important; 
    }
    #adminSidebar {
        z-index: 1999 !important; 
    }
    #sidebarOverlay {
        z-index: 1998 !important;
    }

    .admin-profile-menu {
        display: none; position: absolute; right: 0; top: 100%; margin-top: 15px;
        background: #fff; border: 1px solid #f0d6db; border-radius: 12px;
        box-shadow: 0 8px 24px rgba(201,106,127,0.15); min-width: 200px;
        z-index: 2001; flex-direction: column;
    }
    .admin-profile-menu.show { display: flex; }
    .admin-profile-header { padding: 16px; display: flex; flex-direction: column; text-align: left;}
    .admin-profile-header strong { font-family: 'Poppins', sans-serif; font-size: 0.9rem; color: #2a2a2a; }
    .admin-profile-header span { font-family: 'Poppins', sans-serif; font-size: 0.75rem; color: #b8929f; }
    .admin-profile-div { border: none; border-top: 1px solid #f0d6db; margin: 0; }
    .admin-profile-link {
        font-family: 'Poppins', sans-serif; font-size: 0.85rem; color: #3a3a3a;
        padding: 12px 16px; text-decoration: none; text-align: left;
        background: none; border: none; cursor: pointer; width: 100%;
        transition: background 0.15s, color 0.15s;
    }
    .admin-profile-link:hover { background: #fde8ed; color: #c96a7f; }
    .admin-profile-link:last-child { border-bottom-left-radius: 12px; border-bottom-right-radius: 12px; }
</style>
</head>
<body>

    <header>
        <nav>
            <div class="TopNav">
                <div class="admin-left-nav navbox">
                    <button class="hamburger-btn" id="hamburgerBtn"
                            aria-label="Toggle navigation" aria-expanded="false" aria-controls="adminSidebar">
                        <span></span><span></span><span></span>
                    </button>
                    <img src="~/images/Layout/Black_Logo.png" alt="Logo" class="admin-logo" />
                </div>
                <div class="Brand navbox">
                    <a href="#">HARU</a>
                    <span class="AdminBadge">Admin Panel</span>
                </div>
                <div class="TopMenu navbox">
                    <ul>
                        <li class="TopMenu_search"><a href="#"><img src="~/images/Layout/Search-icon.png" alt="Search" /></a></li>
                        
                        <li class="TopMenu_user admin-top-profile">
                            <button id="adminProfileBtn" class="admin-top-btn">
                                <img src="~/images/Layout/User-icon.png" alt="User" />
                            </button>
                            <div id="adminProfileMenu" class="admin-profile-menu">
                                <div class="admin-profile-header">
                                    <strong>Admin Workspace</strong>
                                    <span>Authorized Access</span>
                                </div>
                                <hr class="admin-profile-div" />
                                <button type="button" class="admin-profile-link" onclick="document.getElementById('adminLogoutForm').submit();">
                                    Logout Session
                                </button>
                            </div>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="admin-body">

        <aside class="admin-sidebar" id="adminSidebar">
            <span class="sidebar-label">Main</span>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-controller="Admin" asp-action="Dashboard">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                Dashboard
            </a>
            <span class="sidebar-label">Manage</span>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Lookbooks" ? "active" : "")"
               asp-controller="Admin" asp-action="Lookbooks">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                Lookbooks
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ProductManagement" ? "active" : "")"
               asp-controller="Admin" asp-action="ProductManagement">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                Product Management
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")"
               asp-controller="Admin" asp-action="Orders">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Orders
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")"
               asp-controller="Admin" asp-action="Users">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Users
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "CustomerInsights" ? "active" : "")"
               asp-controller="Admin" asp-action="CustomerInsights">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                Customer Insights
            </a>
            <hr class="sidebar-divider" />
            
            <div class="sidebar-logout">
                <form asp-controller="Account" asp-action="Logout" method="post" id="adminLogoutForm" style="margin: 0; padding: 0;">
                    <button type="submit" class="sidebar-link" style="width: 100%; text-align: left; background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 10px;">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Logout
                    </button>
                </form>
            </div>

        </aside>

        <div class="admin-content">
            <main role="main">
                @RenderBody()
            </main>


            <footer class="hft">
                <div class="hft-container">
                    <div class="hft-links">
                        <a href="https://www.facebook.com/harumarketofficial" target="_blank" rel="noopener">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                            @@harumarketofficial
                        </a>
                        <a href="https://www.instagram.com/harumarketofficial" target="_blank" rel="noopener">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                            @@harumarketofficial
                        </a>
                        <a href="https://www.tiktok.com/harumarketofficial" target="_blank" rel="noopener">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
                            @@harumarketofficial
                        </a>
                        <a href="mailto:haru.marketofficial@gmail.com">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            haru.marketofficial@@gmail.com
                        </a>
                    </div>
                </div>
            </footer>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const profileBtn = document.getElementById('adminProfileBtn');
            const profileMenu = document.getElementById('adminProfileMenu');

            if (profileBtn && profileMenu) {
                profileBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    profileMenu.classList.toggle('show');
                });

                document.addEventListener('click', function (e) {
                    if (!profileBtn.contains(e.target) && !profileMenu.contains(e.target)) {
                        profileMenu.classList.remove('show');
                    }
                });
            }
        });
    </script>
</body>
</html>
