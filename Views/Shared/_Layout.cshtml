<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Haru.Market</title>
    <script type="importmap"></script>
    <link rel="icon" type="image/png" href="~/images/Layout/Site_Ico.ico" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/costumer_page/Site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/costumer_page/Layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/costumer_page/popup/PopupBase.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/costumer_page/popup/Search.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/costumer_page/popup/Favorites.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/costumer_page/popup/User.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/costumer_page/popup/Cart.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;600&family=Piazzolla:wght@700&display=swap" rel="stylesheet">
  
    <link rel="stylesheet" href="~/haru.market.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@200..1000&family=Piazzolla:opsz,wght@8..30,100..900&display=swap" rel="stylesheet">    
</head>
<body>
    <header>
        <input type="hidden" id="userIsLoggedIn" value="@(User?.Identity?.IsAuthenticated == true ? "true" : "false")" />
        <nav class="">
            <div class="TopNav">
                <div class="Logo ">
                    <img src="~/images/Layout/Black_logo.png"  alt="Logo">                
                </div>
                <div class="Brand "><a href="/Home/Index">HARU</a></div>
                <div class="TopMenu">
                    <ul>
                        <li class="TopMenu_search"><a href="#" id="searchBtn"><img src="~/images/Layout/Search-icon.png"  alt="Logo"></a></li>
                        <li class="TopMenu_user"><a href="#" id="userBtn"><img src="~/images/Layout/User-icon.png"  alt="Logo"></a></li>
                        <li class="TopMenu_heart"><a href="#" id="heartBtn"><img src="~/images/Layout/Heart-icon.png"  alt="Logo"></a></li>
                        <li class="TopMenu_bag"><a href="#" id="bagBtn"><img src="~/images/Layout/Bag-icon.png"  alt="Logo"></a></li> 
                    </ul>
                </div>
            </div>
            <div class="BottomNav">
                <ul>
                    <li>
                        <a href="/Home/Index" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">Home</a>
                    </li>
                    <li>
                        <a href="/Home/Shop" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Shop" ? "active" : "")">Shop</a>
                    </li>
                    <li>
                        <a href="/Home/Lookbook" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Lookbook" ? "active" : "")">Lookbook</a>
                    </li>    
                </ul>
            </div>
        </nav>
    </header>
    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class=" footer text-muted">
        <div class="footer_container"></div>
    </footer>

    <partial name="Popups/_Search_Popup_Page" />
    <div id="haruFavoritesContainer">
        <partial name="Popups/_Favorites_Popup_Page" model="new List<haru.market.Models.FavoriteItemViewModel>()" />
    </div>
    <partial name="Popups/_User_Popup_Page" />
    
    <div id="globalCartModalOverlay" class="haru-cart-modal-backdrop" onclick="closeCartModal(event)">
        <div class="haru-cart-popup-window-shell">
            <button type="button" class="haru-cart-global-close-x" onclick="forceCloseCartModal()">&times;</button>
            <div id="haruLiveCartInnerContent" style="width:100%; height:100%;">
                <partial name="Popups/_Cart_Popup_Page" model="new List<haru.market.Models.CartItemViewModel>()" />
            </div>
        </div>
    </div>

    <div id="accountRequiredModal" class="haru-modal-overlay" onclick="closeGlobalAuthModal()">
        <div class="haru-modal-card" onclick="event.stopPropagation()">
            <button type="button" class="haru-modal-close-btn" onclick="closeGlobalAuthModal()">&times;</button>
            <div class="haru-modal-body">
                <div class="haru-modal-icon-wrap">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#EB899D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </div>
                <h2>Account Required</h2>
                <p>Please log in or sign up to add items directly to your personal Haru shopping bag!</p>
                <div class="haru-modal-actions">
                    <button type="button" class="haru-modal-btn-secondary" onclick="closeGlobalAuthModal()">Cancel</button>
                    <button type="button" class="haru-modal-btn-primary" onclick="redirectGlobalToLogin()">Log In</button>
                </div>
            </div>
        </div>
    </div>

    <div id="loginModalOverlay" class="login-modal-overlay" style="display: none;">
        <div class="login-modal-content">
            <partial name="Popups/_User_Popup_Page" />
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/Popup/cart.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        function openGlobalAuthModal() {
            const targetModal = document.getElementById("accountRequiredModal");
            if (targetModal) {
                targetModal.classList.add("show-popup");
                document.body.style.overflow = "hidden"; 
            }
        }

        function closeGlobalAuthModal() {
            const targetModal = document.getElementById("accountRequiredModal");
            if (targetModal) {
                targetModal.classList.remove("show-popup");
                document.body.style.overflow = ""; 
            }
        }

        function redirectGlobalToLogin() {
            closeGlobalAuthModal();
            const currentPath = encodeURIComponent(window.location.pathname + window.location.search);
            window.location.href = `/Account/Login?returnUrl=${currentPath}`;
        }

        document.addEventListener("DOMContentLoaded", function () {
            // ── Heart / Favorites button ─────────────────────────────────────
            const heartBtn = document.getElementById("heartBtn");
            if (heartBtn) {
                heartBtn.setAttribute("href", "javascript:void(0)");
                heartBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    openFavoritesModal();
                });
            }

            const closeHeartEl = document.getElementById("closeHeart");
            if (closeHeartEl) {
                closeHeartEl.addEventListener("click", function (e) {
                    e.preventDefault();
                    closeFavoritesModal();
                });
            }

            // ── Bag button ───────────────────────────────────────────────────
            const bagButton = document.getElementById("bagBtn");
            
            if (bagButton) {
                bagButton.setAttribute("href", "javascript:void(0)");
                bagButton.addEventListener("click", function (e) {
                    e.preventDefault();

                    const authInput = document.getElementById('userIsLoggedIn');
                    const isLoggedIn = authInput ? authInput.value === 'true' : false;

                    if (!isLoggedIn) {
                        openGlobalAuthModal();
                    } else {
                        openCartModal();
                    }
                });
            }
        });

        function openCartModal() {
            fetch('/Cart/GetCartPartial')
                .then(response => {
                    if (response.redirected) throw new Error("AUTH_REDIRECT");
                    if (!response.ok) throw new Error("Network exception: " + response.status);
                    return response.text();
                })
                .then(htmlContent => {
                    if (htmlContent.trim().toLowerCase().startsWith('<!doctype html>') || htmlContent.includes('<html')) {
                        throw new Error("AUTH_REDIRECT");
                    }

                    const dataContainer = document.getElementById("haruLiveCartInnerContent");
                    const overlayWrapper = document.getElementById("globalCartModalOverlay");
                    
                    if (dataContainer && overlayWrapper) {
                        dataContainer.innerHTML = htmlContent;
                        setTimeout(() => {
                            overlayWrapper.classList.add("show-popup-drawer");
                        }, 10);
                    }
                })
                .catch(error => {
                    if (error.message === "AUTH_REDIRECT") {
                        openGlobalAuthModal();
                    } else {
                        console.error("Fetch error processing system pipeline:", error);
                    }
                });
        }

        function closeCartModal(e) {
            if (e && e.target && e.target.id === "globalCartModalOverlay") {
                document.getElementById("globalCartModalOverlay").classList.remove("show-popup-drawer");
            }
        }

        function forceCloseCartModal() {
            const overlayWrapper = document.getElementById("globalCartModalOverlay");
            if (overlayWrapper) {
                overlayWrapper.classList.remove("show-popup-drawer");
            }
        }

        function openFavoritesModal() {
            const isLoggedIn = @(User?.Identity?.IsAuthenticated.ToString().ToLower() ?? "false");

            if (!isLoggedIn) {
                openGlobalAuthModal();
                return;
            }

            fetch('/Favorites/GetFavoritesPartial')
                .then(response => {
                    if (response.redirected || !response.ok) throw new Error("AUTH_REDIRECT");
                    return response.text();
                })
                .then(htmlContent => {
                    if (htmlContent.trim().toLowerCase().startsWith('<!doctype html>') || htmlContent.includes('<html')) {
                        throw new Error("AUTH_REDIRECT");
                    }
                    const container = document.getElementById("haruFavoritesContainer");
                    if (container) {
                        container.innerHTML = htmlContent;
                        // Re-bind close button after re-render
                        const closeBtn = document.getElementById("closeHeart");
                        if (closeBtn) closeBtn.addEventListener("click", function(e) {
                            e.preventDefault();
                            closeFavoritesModal();
                        });
                    }
                    const popup = document.getElementById("heartPopup");
                    if (popup) {
                        popup.classList.add("show-popup");
                        document.body.style.overflow = "hidden";
                    }
                })
                .catch(error => {
                    if (error.message === "AUTH_REDIRECT") {
                        openGlobalAuthModal();
                    } else {
                        console.error("Favorites modal error:", error);
                    }
                });
        }

        function closeFavoritesModal() {
            const popup = document.getElementById("heartPopup");
            if (popup) {
                popup.classList.remove("show-popup");
                document.body.style.overflow = "";
            }
        }

        function handleBagClick(e) {
            if (e) e.preventDefault();

            const btn = document.querySelector(".nav-bag-btn");
            const isAuthenticated = btn.getAttribute("data-authenticated") === "true";

            if (isAuthenticated) {
                openCartDrawer(); 
            } else {
                showLoginModal(); 
            }
        }
    </script>
</body>
</html>
