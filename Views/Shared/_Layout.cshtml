<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - haru.market</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/haru.market.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)

    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@200..1000&display=swap" rel="stylesheet">
    
</head>
<body>
    <header>
        <nav class="">
            <div class="TopNav">
                <div class="Logo ">
                        <img src="~/images/Layout/Black_logo.png"  alt="Logo">                
                </div>
                <div class="Brand "><a href="/Home/Index">HARU</a></div>
                <div class="TopMenu">
                    <ul>
                        <li class="TopMenu_search"><a href="#"><img src="~/images/Layout/Search-icon.png"  alt="Logo"></a></li>
                        <li class="TopMenu_user"><a href="#"><img src="~/images/Layout/User-icon.png"  alt="Logo"></a></li>
                        <li class="TopMenu_heart"><a href="#"><img src="~/images/Layout/Heart-icon.png"  alt="Logo"></a></li>
                        <li class="TopMenu_bag"><a href="#"><img src="~/images/Layout/Bag-icon.png"  alt="Logo"></a></li> 
                    </ul>

                </div>
            </div>
            <div class="BottomNav">
                <ul>
                    <li><a href="/Home/Index">Home</a></li>
                    <li><a href="/Home/Shop">Shop</a></li>
                    <li><a href="/Home/Lookbook">Lookbook</a></li>   
                </ul>
            </div>
        </nav>
    </header>
    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class=" footer text-muted">
        <div class="footer_container">
            <img src="~/images/Layout/Footer.png"  alt="Logo">
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
