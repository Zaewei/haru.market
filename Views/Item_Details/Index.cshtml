@model haru.market.Models.ProductViewModel
@using System.Text.Encodings.Web

@section Styles {
    <link rel="stylesheet" href="~/css/Item_Details/Item_Details.css" asp-append-version="true" />
    <style>
        .haru-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(26, 21, 22, 0.35);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
        }

        .haru-modal-overlay.show-popup {
            opacity: 1;
            pointer-events: auto;
        }

        .haru-modal-card {
            background-color: #ffffff;
            border: 2px solid #f2d6dc;
            border-radius: 20px;
            width: 90%;
            max-width: 440px;
            box-shadow: 0 20px 50px rgba(201, 106, 127, 0.12);
            position: relative;
            transform: translateY(-25px);
            transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
            padding: 40px 30px 35px 30px;
            box-sizing: border-box;
        }

        .haru-modal-overlay.show-popup .haru-modal-card {
            transform: translateY(0);
        }

        .haru-modal-close-btn {
            position: absolute;
            top: 18px;
            right: 22px;
            background: none;
            border: none;
            font-size: 26px;
            color: #bbb;
            cursor: pointer;
            transition: color 0.15s ease, transform 0.15s ease;
            line-height: 1;
        }

        .haru-modal-close-btn:hover {
            color: #EB899D;
            transform: scale(1.1);
        }

        .haru-modal-body {
            text-align: center;
        }

        .haru-modal-icon-wrap {
            width: 64px;
            height: 64px;
            background-color: #fff5f7;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px auto;
            border: 1px solid #f2d6dc;
        }

        .haru-modal-body h2 {
            font-family: "Piazzolla", serif;
            font-weight: 800;
            font-size: 1.7rem;
            color: #111111;
            margin: 0 0 12px 0;
            letter-spacing: -0.01em;
        }

        .haru-modal-body p {
            font-family: "Nunito", sans-serif;
            font-size: 0.98rem;
            font-weight: 600;
            color: #666666;
            line-height: 1.55;
            margin: 0 0 30px 0;
        }

        .haru-modal-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            width: 100%;
        }

        .haru-modal-btn-primary {
            height: 48px;
            flex: 1;
            border: none;
            border-radius: 10px;
            background-color: #EB899D;
            color: #ffffff;
            font-family: "Nunito", sans-serif;
            font-weight: 800;
            font-size: 0.95rem;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(235, 137, 157, 0.25);
            transition: all 0.2s ease;
        }

        .haru-modal-btn-primary:hover {
            background-color: #c96a7f;
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(235, 137, 157, 0.35);
        }

        .haru-modal-btn-secondary {
            height: 48px;
            padding: 0 22px;
            border: 2px solid #f2d6dc;
            background-color: #ffffff;
            border-radius: 10px;
            font-family: "Nunito", sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            color: #888888;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .haru-modal-btn-secondary:hover {
            background-color: #fff5f7;
            color: #c96a7f;
            border-color: #EB899D;
        }
    </style>
}

<div class="back_button_container">
    <a href="@Url.Action("Shop", "Home")" class="haru-back-link">&larr; Back to Catalog</a>
</div>

<section class="Item_Details_Workspace">

    <div class="Media_Showcase_Panel">
        <div class="Main_Display_Canvas">
            <img id="primaryProductCanvas" src="@Model.ImageUrl" alt="@Model.Name" />
        </div>
        
        <div class="Thumbnail_Selector_Strip">
            <div class="Thumbnail_Card active-thumb" style="background-image: url('@Model.ImageUrl');" 
                 onclick="document.getElementById('primaryProductCanvas').src='@Model.ImageUrl'"></div>

            @if (!string.IsNullOrEmpty(Model.Imageurl2))
            {
                <div class="Thumbnail_Card" style="background-image: url('@Model.Imageurl2');" 
                     onclick="document.getElementById('primaryProductCanvas').src='@Model.Imageurl2'"></div>
            }
        </div>
    </div>

    <div class="Product_Configuration_Panel">

        <div class="Product_Header_Block">
            <h1 class="Product_Main_Title">@Model.Name</h1>
            <p class="Product_Main_Price">₱@Model.Price</p>
        </div>

        <div class="Variant_Selector_Group">
            <span class="Selector_Label">Color: <span class="Active_Label_Value">@(string.IsNullOrEmpty(Model.Color) ? "Standard" : Model.Color)</span></span>
            <div class="Color_Bubbles_Row">
                @if (ViewData["Variants"] != null)
                {
                    var variantList = (List<haru.market.Models.ProductViewModel>)ViewData["Variants"]!;
                    foreach (var variant in variantList)
                    {
                        var isCurrentlySelected = variant.Id == Model.Id;
                        
                        string bubbleHex = "#cccccc";
                        if (!string.IsNullOrEmpty(variant.Color))
                        {
                            switch (variant.Color.ToLower().Trim())
                            {
                                case "black": bubbleHex = "#1a1a1a"; break;
                                case "white": bubbleHex = "#ffffff"; break;
                                case "stitched": bubbleHex = "#2b2526"; break;
                                case "pink": bubbleHex = "#FFBCCB"; break;
                            }
                        }

                        <a href="@Url.Action("Index", "Item_Details", new { id = variant.Id })" 
                           class="Color_Swatch_Circle @(isCurrentlySelected ? "active-swatch" : "")" 
                           style="background-color: @bubbleHex; border: 1px solid @(bubbleHex.ToLower() == "#ffffff" ? "#ddd" : "transparent");"
                           title="Switch color to @variant.Color">
                        </a>
                    }
                }
            </div>
        </div>

        <div class="Variant_Selector_Group">
            <span class="Selector_Label">Select Size</span>
            <div class="Size_Buttons_Grid">
                <button type="button" class="Size_Button">S</button>
                <button type="button" class="Size_Button active">M</button>
                <button type="button" class="Size_Button">L</button>
                <button type="button" class="Size_Button">XL</button>
                <button type="button" class="Size_Button">XXL</button>
            </div>
            <a href="#" class="Size_Guide_Link">View Measurement Size Guide</a>
        </div>

        <div class="Purchase_Execution_Row">
            <div class="Quantity_Selector_Widget">
                <button type="button" id="minusBtn" class="Qty_Control_Btn">&minus;</button>
                <input type="text" id="quantity" name="Quantity" value="1" readonly class="Qty_Display_Input">
                <button type="button" id="plusBtn" class="Qty_Control_Btn">+</button>
            </div>

            <div class="Action_Buttons_Wrapper">
               <button type="button" class="Haru_Primary_Bag_Btn" onclick="handleAddToCartClick()">Add to Bag</button>
                
                <input type="checkbox" id="fav1" hidden>
                <label for="fav1" class="Haru_Heart_Wish_Label">
                    <svg class="heart-icon" viewBox="0 0 24 24" width="26" height="26">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                    </svg>
                </label>
            </div>
        </div>

    </div>

</section>

<div id="authRequiredModal" class="haru-modal-overlay" onclick="closeAuthModal()">
    <div class="haru-modal-card" onclick="event.stopPropagation()">
        <button type="button" class="haru-modal-close-btn" onclick="closeAuthModal()">&times;</button>
        <div class="haru-modal-body">
            <div class="haru-modal-icon-wrap">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#EB899D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <h2>Account Required</h2>
            <p>Please log in or sign up to add items directly to your personal Haru shopping bag!</p>
            <div class="haru-modal-actions">
                <button type="button" class="haru-modal-btn-secondary" onclick="closeAuthModal()">Cancel</button>
                <button type="button" class="haru-modal-btn-primary" onclick="redirectToLogin()">Log In</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Item_Details/Item_Details.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sizeButtons = document.querySelectorAll(".Size_Button");
            sizeButtons.forEach(btn => {
                btn.addEventListener("click", function () {
                    sizeButtons.forEach(b => b.classList.remove("active"));
                    this.classList.add("active");
                });
            });
        });

        function openAuthModal() {
            document.getElementById("authRequiredModal").classList.add("show-popup");
            document.body.style.overflow = "hidden"; // Prevents background body scrolling
        }

        function closeAuthModal() {
            document.getElementById("authRequiredModal").classList.remove("show-popup");
            document.body.style.overflow = ""; // Restores normal scrolling
        }

        function redirectToLogin() {
            closeAuthModal();
            const currentPagePath = encodeURIComponent(window.location.pathname + window.location.search);
            window.location.href = `/Account/Login?returnUrl=${currentPagePath}`;
        }

        function handleAddToCartClick() {
            const isUserLoggedIn = @(User.Identity?.IsAuthenticated.ToString().ToLower() ?? "false");
            const activeSizeElement = document.querySelector(".Size_Button.active");
            const selectedSize = activeSizeElement ? activeSizeElement.innerText.trim() : "M";

            const quantityInput = document.getElementById("quantity");
            const selectedQty = quantityInput ? parseInt(quantityInput.value) : 1;

            if (!isUserLoggedIn) {
                openAuthModal();
                return;
            }

            const cartPayload = {
                productId: "@Model.Id",
                size: selectedSize,
                quantity: selectedQty
            };

            console.log("Dispatching item data bundle down to database pipeline:", cartPayload);

            fetch('/Cart/Add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(cartPayload)
            })
            .then(response => {
                if (!response.ok) throw new Error("HTTP connection error status: " + response.status);
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    if (typeof openCartModal === "function") {
                        openCartModal();
                    }
                } else {
                    alert("Could not update your bag: " + data.message);
                }
            })
            .catch(error => console.error("Network communication connection dropped:", error));
        }
</script>
}