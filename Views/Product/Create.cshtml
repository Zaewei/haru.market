@model haru.market.Models.ProductViewModel

<div class="container" style="padding: 50px;">
    <h2>Admin - Test Product Creation</h2>
    
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" style="color:red;"></div>

        <div>
            <label>Product Name:</label><br />
            <input asp-for="Name" style="width: 300px;" /><br /><br />
        </div>
        <div>
            <label>Description:</label><br />
            <textarea asp-for="Description" style="width: 300px; height: 100px;"></textarea><br /><br />
        </div>
        <div>
            <label>Price ($):</label><br />
            <input asp-for="Price" type="number" step="0.01" /><br /><br />
        </div>
        <div>
            <label>Initial Stock Quantity:</label><br />
            <input asp-for="StockQuantity" type="number" /><br /><br />
        </div>
        <div>
            <label>Image URL (Optional):</label><br />
            <input asp-for="ImageUrl" style="width: 300px;" /><br /><br />
        </div>

        <button type="submit" style="padding: 10px 20px;">Publish Product to Cloud</button>
    </form>
</div>