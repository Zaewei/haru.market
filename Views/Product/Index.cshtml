@model IEnumerable<haru.market.Models.ProductViewModel>

<div class="container" style="padding: 50px;">
    <h2 style="margin-bottom: 30px;">Customer Catalog Display</h2>

    @if (!Model.Any())
    {
        <p>The shop shelves are currently empty!</p>
    }
    else
    {
        <div style="display: flex; flex-wrap: wrap; gap: 25px;">
            @foreach (var item in Model)
            {
                <div style="border: 1px solid #ccc; border-radius: 8px; padding: 20px; width: 280px; box-shadow: 2px 2px 8px rgba(0,0,0,0.05); background: #fff; display: flex; flex-direction: column; justify-content: space-between;">
                    <div>
                        <div style="width: 100%; height: 200px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #f9f9f9; border-radius: 4px; margin-bottom: 15px;">
                            <img src="@item.ImageUrl" alt="@item.Name" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                        </div>

                        <h3 style="margin-top: 0; color: #333; font-size: 1.3em;">@item.Name</h3>
                        <p style="font-size: 0.9em; color: #666; min-height: 50px; margin-bottom: 15px;">@item.Description</p>
                    </div>
                    
                    <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #eee; padding-top: 15px;">
                        <strong style="color: #e91e63; font-size: 1.2em;">$@item.Price</strong>
                        <span style="font-size: 0.85em; background: #eee; padding: 3px 8px; border-radius: 4px; color: #333;">
                            Stock: @item.StockQuantity
                        </span>
                    </div>
                </div>
            }
        </div>
    }
    
    <div style="margin-top: 40px;">
        <a href="/Product/Create" style="background: #333; color: #fff; padding: 10px 15px; text-decoration: none; border-radius: 4px;">
            + Add Another Product
        </a>
    </div>
</div>